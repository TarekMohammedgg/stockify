      "id": "b6d3df55-a0e6-4932-88af-9dfbef3ae24d",
      "name": "Order Confirmed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [480, 336]
    },
    {
      "parameters": {
        "jsCode": "\nconst raw = $input.first().json.output;\nconst jsonStr = raw.replace('ORDER_CONFIRMED:', '').trim();\nconst order = JSON.parse(jsonStr);\n\nconst itemLines = order.items.map(i =>\n  `  • ${i.name} x${i.quantity} — ${i.price * i.quantity} EGP`\n).join('\\n');\n\nconst confirmationMsg =\n  `✅ تم استلام طلبك! / Order received!\\n\\n` +\n  `🧾 ${itemLines}\\n\\n` +\n  `💰 Total: ${order.total} EGP\\n` +\n  (order.notes ? `📝 Notes: ${order.notes}\\n` : '') +\n  `\\nسيتم التواصل معك قريباً / We will contact you soon! 🙏`;\n\nreturn [{\n  json: {\n    customer_phone: order.customer_phone,\n    items: order.items,\n    total_price: order.total,\n    source: 'whatsapp',\n    type: 'delivery',\n    status: 'pending',\n    notes: order.notes || '',\n    replyText: confirmationMsg,\n    senderId: order.customer_phone\n  }\n}];\n"
      },
