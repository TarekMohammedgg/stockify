    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst menuItems = [];\nlet restaurantInfo = {};\n\nfor (const item of items) {\n  if (item.json._source === 'menu') {\n    menuItems.push(item.json);\n  } else if (item.json._source === 'info') {\n    restaurantInfo = item.json;\n  }\n}\n\nconst menuText = menuItems.map(m =>\n  `• ${m.name} — ${m.description ?? ''} | Price: ${m.price} EGP${m.category ? ' | Category: ' + m.category : ''}`\n).join('\\n');\n\nreturn [{\n  json: {\n    menuContext: menuText || 'Menu not available at the moment.',\n    restaurantContext: `Name: ${restaurantInfo.name ?? 'Our Restaurant'}\\nAddress: ${restaurantInfo.address ?? 'N/A'}\\nPhone: ${restaurantInfo.phone ?? 'N/A'}\\nHours: ${restaurantInfo.working_hours ?? 'N/A'}`,\n    senderId: $('Extract Message').first().json.senderId,\n    messageText: $('Extract Message').first().json.messageText,\n    sessionKey: $('Extract Message').first().json.sessionKey\n  }\n}];\n"
      },
