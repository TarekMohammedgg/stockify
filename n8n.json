        "jsCode": "\nconst orderId = $('Save Order').first().json.id;\nconst items = $('Parse Order').first().json.items;\n\nreturn items.map(item => ({\n  json: {\n    order_id: orderId,\n    menu_item_id: item.id,\n    quantity: item.quantity,\n    unit_price: item.price,\n    notes: ''\n  }\n}));\n"
