      "id": "ff5f5744-f529-4a21-8d12-36417abeb452",
      "name": "Tag Menu Rows",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-320, 336]
    },
    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst menuItems = [];\n\nfor (const item of items) {\n  if (item.json._source === 'menu') {\n    menuItems.push(item.json);\n  }\n}\n\nconst menuText = menuItems\n  .filter(m => m.is_available !== false)\n  .map(m =>\n    `• [${m.id}] ${m.name_en} / ${m.name_ar} — Price: ${m.price} EGP | Category: ${m.category_en}`\n  ).join('\\n');\n\nreturn [{\n  json: {\n    menuContext: menuText || 'Menu not available at the moment.',\n    restaurantContext: 'Name: Stockify Restaurant\\nAddress: Contact us for details\\nPhone: Contact via WhatsApp\\nHours: Daily 10:00 AM – 11:00 PM',\n    senderId: $('Extract Message').first().json.senderId,\n    messageText: $('Extract Message').first().json.messageText,\n    sessionKey: $('Extract Message').first().json.sessionKey\n  }\n}];\n"
      },
      "id": "7218b325-c5df-4a5b-bc9f-214e01a0a365",
      "name": "Build Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-96, 336]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": {
          "status": "received"
        },
        "options": {
          "responseCode": 200
        }
      },
      "id": "f7c1c729-d5c2-49cb-ad35-f7151b8dec89",
      "name": "Acknowledge Webhook",
